  "tools": [
    {
      "name": "get_restaurant_info",
      "display_name": "门店信息查询",
      "description": "查询五代同糖门店信息。可指定城市查找对应门店，不传参数则返回全部门店列表。包含地址、营业时间、门店特色。",
