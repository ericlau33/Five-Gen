      "description": "查询五代同糖甜品菜单。可指定分类（招牌必点/雪花冰/麻薯/河粉肠粉/经典糖水），不传则返回完整菜单含价格。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "description": "分类名（可选），如：招牌必点、雪花冰"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
