        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "description": "城市名（可选），如：广州、深圳"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "get_menu_info",
